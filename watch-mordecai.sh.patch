 case "$STATUS" in
+  planning)
+    # Mordecai is generating a plan — check if the plan process finished
+    PLAN_PID=$(ps aux | grep "mordecai-plan.sh.*$ISSUE" | grep -v grep | awk '{print $2}' | head -1)
+    if [ -n "$PLAN_PID" ]; then
+      echo "Plan generation still running for issue #$ISSUE (PID $PLAN_PID)."
+    else
+      # Plan process finished — check if state was updated to awaiting_approval
+      CURRENT_STATUS=$(python3 -c "import json; print(json.load(open('$STATE_FILE')).get('status',''))" 2>/dev/null)
+      if [ "$CURRENT_STATUS" = "awaiting_approval" ]; then
+        echo "Plan posted, now awaiting approval for issue #$ISSUE."
+      elif [ "$CURRENT_STATUS" = "escalated" ]; then
+        echo "Plan generation failed for issue #$ISSUE. Escalated."
+      else
+        echo "Plan process exited but status is '$CURRENT_STATUS'. May need investigation."
+      fi
+    fi
+    exit 0
+    ;;
+
+  awaiting_approval)
+    # Plan posted, waiting for Josh's reaction
+    REACTION_RESULT=$(bash "$CHECK_PLAN_SH" 2>/dev/null)
+    case "$REACTION_RESULT" in
+      approved)
+        echo "Plan approved for issue #$ISSUE. Starting implementation."
+        # Spawn Mordecai in full implementation mode (reuse existing restart logic)
+        FULL_PROMPT="$(cat "$TASK_FILE")
+
+## Approved plan
+$(cat "$HOME/.config/mordecai-watcher/plan-$ISSUE.json" 2>/dev/null || echo 'See Discord for plan.')
+
+Implement the plan above. Follow the plan closely."
+
+        cd "$WORKDIR"
+        nohup claude --dangerously-skip-permissions "$FULL_PROMPT" >> "$LOG_FILE" 2>&1 &
+        IMPL_PID=$!
+        agent_register mordecai "issue #$ISSUE (implementing)" "$WORKDIR" "$IMPL_PID"
+        notify "🔩 **Mordecai** starting implementation for issue #$ISSUE (PID $IMPL_PID)."
+        ;;
+      corrections)
+        echo "Corrections requested for issue #$ISSUE. Waiting for Josh's input."
+        ;;
+      *)
+        echo "Still waiting for approval on issue #$ISSUE plan."
+        ;;
+    esac
+    exit 0
+    ;;
+
+  correcting)
+    echo "Status is correcting for issue #$ISSUE. Waiting for Zev to re-run plan after Josh provides corrections."
+    exit 0
+    ;;
+
+  implementing)
+    # Treat same as active — check if Mordecai is running, handle PR, restart, etc.
+    echo "Status is implementing for issue #$ISSUE. Falling through to active monitoring."
+    ;;
+
   pr_open)
     echo "Status is pr_open (PR #${PR_NUMBER:-?}). Checking if merged..."
